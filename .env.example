# Server-only Firebase configuration. Do not prefix these with NEXT_PUBLIC_.
FIREBASE_PROJECT_ID=orymu-validation-engine

# Prefer workload identity / Application Default Credentials when the hosting
# platform supports it. Otherwise configure both values in its secret manager.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# A random secret of at least 32 characters used to HMAC email and IP values.
WAITLIST_HASH_SECRET=

# This deployment only writes to this product's subcollection.
WAITLIST_PRODUCT_ID=awwabi

# Comma-separated production origins, for example https://awwabi.app.
WAITLIST_ALLOWED_ORIGINS=

# Must be approved as part of the privacy/data-retention policy.
WAITLIST_RETENTION_DAYS=365

# Distributed fixed-window limit, enforced through Firestore.
WAITLIST_RATE_LIMIT_MAX=5
WAITLIST_RATE_LIMIT_WINDOW_SECONDS=60
